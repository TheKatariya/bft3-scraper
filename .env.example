# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

BFT_EMAIL=your-email@example.com
BFT_PASSWORD=your-password-here

# Output mode (optional)
# OUTPUT_MODE=json  → outputs JSON array to stdout (default, used by n8n)
# OUTPUT_MODE=csv   → writes a CSV file to /app/output/bft3sessions-YYYY-MM-DD.csv
#                     volume-mount that directory to retrieve the file
OUTPUT_MODE=csv
