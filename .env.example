# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

BFT_EMAIL=your-email@example.com
BFT_PASSWORD=your-password-here

# OUTPUT_MODE=json  → JSON array to stdout (default, used by n8n)
# OUTPUT_MODE=csv   → CSV written to /app/output/bft3sessions-YYYY-MM-DD.csv
#                     (volume-mount /app/output to retrieve the file)
OUTPUT_MODE=json
